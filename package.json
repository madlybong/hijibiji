{
  "name": "gmdesigner-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/ui"
  ],
  "scripts": {
    "dev": "bun --cwd apps/desktop dev",
